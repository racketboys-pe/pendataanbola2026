rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // configs collection
    match /configs/main {
      allow read: if true;
      allow write: if true;
    }

    // registrations collection
    match /registrations/{registrationId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
